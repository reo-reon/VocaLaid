# ──────────────────────────────────────────
# ローカル開発用
# ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vocalaid_dev?schema=public"
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:5432/vocalaid_dev?schema=public"

# フロントエンドのオリジン（CORSに使用）
FRONTEND_URL="http://localhost:3001"

# 実行環境（development | production）
NODE_ENV="development"

# ──────────────────────────────────────────
# Neon 本番用（App Service の環境変数に設定）
# ──────────────────────────────────────────
# Neon の「Connection string」ページから取得
# DATABASE_URL      = 接続プールURL（Pooled connection）
# DATABASE_URL_DIRECT = 直接接続URL（Direct connection）※マイグレーション用
#
# DATABASE_URL="postgresql://<user>:<pass>@ep-xxx.ap-southeast-1.aws.neon.tech/<dbname>?sslmode=require"
# DATABASE_URL_DIRECT="postgresql://<user>:<pass>@ep-xxx.ap-southeast-1.aws.neon.tech/<dbname>?sslmode=require"
# FRONTEND_URL="https://<your-app>.azurestaticapps.net"
# NODE_ENV="production"
# PORT は Azure が自動設定するため不要
